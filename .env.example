# Copy this file to .env and fill in local values.
# Never commit .env.

# Runtime
STRATEGY_LAB_ENV=local
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# DeepSeek OpenAI-compatible endpoint
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Moonshot/Kimi OpenAI-compatible endpoint
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.6

# Data source: MiniQMT / xtquant
QMT_USERDATA=
QMT_ACCOUNT_ID=

# Optional agent-level model overrides.
# Leave blank to use configs/agent.yaml defaults.
DATA_AGENT_API_KEY=
DATA_AGENT_BASE_URL=
DATA_AGENT_MODEL=

SIGNAL_AGENT_API_KEY=
SIGNAL_AGENT_BASE_URL=
SIGNAL_AGENT_MODEL=

CRITIC_AGENT_API_KEY=
CRITIC_AGENT_BASE_URL=
CRITIC_AGENT_MODEL=

BUDGET_AGENT_API_KEY=
BUDGET_AGENT_BASE_URL=
BUDGET_AGENT_MODEL=

BUDGET_CRITIC_AGENT_API_KEY=
BUDGET_CRITIC_AGENT_BASE_URL=
BUDGET_CRITIC_AGENT_MODEL=

PORTFOLIO_AGENT_API_KEY=
PORTFOLIO_AGENT_BASE_URL=
PORTFOLIO_AGENT_MODEL=

PORTFOLIO_CRITIC_AGENT_API_KEY=
PORTFOLIO_CRITIC_AGENT_BASE_URL=
PORTFOLIO_CRITIC_AGENT_MODEL=
